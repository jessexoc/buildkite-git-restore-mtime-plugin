#!/bin/bash

set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=lib/shared.bash
. "$DIR/../lib/shared.bash"

# shellcheck source=lib/plugin.bash
. "$DIR/../lib/plugin.bash"

# Global variable used by plugin_read_list_into_result
result=()

# Default Docker image used by the `docker` tool-location.
DEFAULT_DOCKER_IMAGE="ghcr.io/jessexoc/git-restore-mtime"

# Echoes each external alternate object directory the checkout depends on, one
# absolute path per line.
#
# When Buildkite's git-mirror feature is enabled the checkout is created with
# `git clone --reference <mirror>` (without --dissociate), which leaves an
# alternates file pointing the work tree's object store at the shared mirror,
# e.g. /var/lib/buildkite-agent/git-mirrors/<repo>-git/objects. The actual
# commit/tree/blob objects live only in that mirror. A container that mounts
# only the work tree therefore can't resolve them, which git reports as
# "unable to normalize alternate object path" followed by "fatal: bad object
# HEAD". Callers mount each returned directory into the container at the same
# path so git resolves objects exactly as it does on the host.
#
# Relies on the global CHECKOUT_PATH. Alternates are followed transitively in
# case a referenced mirror is itself a reference clone.
resolve_alternate_object_dirs() {
  local objects_dir=""
  # Prefer git to locate the object store (it handles worktrees and `.git`
  # gitfiles correctly); fall back to the conventional path so the docker
  # tool-location keeps working on the rare agent without git on PATH.
  if command_exists git; then
    objects_dir=$(git -C "${CHECKOUT_PATH}" rev-parse --git-path objects 2>/dev/null || true)
    # rev-parse may return a path relative to CHECKOUT_PATH.
    if [[ -n "${objects_dir}" && "${objects_dir}" != /* ]]; then
      objects_dir="${CHECKOUT_PATH}/${objects_dir}"
    fi
  fi
  objects_dir="${objects_dir:-${CHECKOUT_PATH}/.git/objects}"

  local -a queue=("${objects_dir}")
  local -A seen=()
  while [[ ${#queue[@]} -gt 0 ]]; do
    local dir="${queue[0]}"
    queue=("${queue[@]:1}")

    local alt_file="${dir}/info/alternates"
    [[ -f "${alt_file}" ]] || continue

    local line
    while IFS= read -r line || [[ -n "${line}" ]]; do
      # git treats blank lines and '#'-prefixed lines in alternates as comments.
      [[ -z "${line}" || "${line}" == \#* ]] && continue
      # A relative alternate is resolved against the object dir holding the file.
      local alt="${line}"
      [[ "${alt}" != /* ]] && alt="${dir}/${alt}"
      [[ -d "${alt}" ]] || continue
      if [[ -z "${seen[${alt}]:-}" ]]; then
        seen[${alt}]=1
        printf '%s\n' "${alt}"
        queue+=("${alt}")
      fi
    done < "${alt_file}"
  done
}

# Populates the global GRM_CMD array with the command used to invoke
# git-restore-mtime, based on the `tool-location` option:
#   docker         -> run the default image, mounting the checkout at /workdir
#   docker:<image> -> run a custom image the same way
#   path           -> use git-restore-mtime found on PATH
#   path:<file>    -> use the executable at the given path
# Relies on the global CHECKOUT_PATH being set to the work tree root.
GRM_CMD=()
resolve_git_restore_mtime() {
  local location
  location=$(plugin_read_config TOOL_LOCATION "docker")

  case "${location}" in
    docker | docker:*)
      local image="${DEFAULT_DOCKER_IMAGE}"
      if [[ "${location}" == docker:* ]]; then
        image="${location#docker:}"
      fi
      if ! command_exists docker; then
        log_error "tool-location is '${location}' but docker is not available on the agent."
        exit 1
      fi
      # Mount the checkout at /workdir and run there so pathspecs resolve
      # relative to the repository root regardless of the image's WORKDIR.
      local -a mounts=(-v "${CHECKOUT_PATH}:/workdir")
      # Also mount any external alternate object stores (e.g. a Buildkite git
      # mirror) at their original host path, so git inside the container can
      # resolve objects that live outside the work tree.
      local alt_dir
      while IFS= read -r alt_dir; do
        [[ -n "${alt_dir}" ]] || continue
        mounts+=(-v "${alt_dir}:${alt_dir}:ro")
        log_info "Mounting alternate object store (git mirror): ${alt_dir}"
      done < <(resolve_alternate_object_dirs)
      GRM_CMD=(docker run --rm "${mounts[@]}" -w /workdir "${image}")
      log_info "Using git-restore-mtime from Docker image: ${image}"
      ;;
    path)
      if ! command_exists git-restore-mtime; then
        log_error "tool-location is 'path' but git-restore-mtime was not found on PATH."
        exit 1
      fi
      GRM_CMD=(git-restore-mtime)
      log_info "Using git-restore-mtime found on PATH"
      ;;
    path:*)
      local tool="${location#path:}"
      if [[ ! -x "${tool}" ]]; then
        log_error "tool-location points to '${tool}', which is not an executable file."
        exit 1
      fi
      GRM_CMD=("${tool}")
      log_info "Using git-restore-mtime at: ${tool}"
      ;;
    *)
      log_error "Invalid tool-location: '${location}'."
      log_error "Expected one of: docker, docker:<image>, path, path:<file>."
      exit 1
      ;;
  esac
}

# Appends a git-restore-mtime flag to the global 'args' array when the given
# boolean config option is enabled.
add_flag_if_enabled() {
  local config_key="$1"
  local flag="$2"
  local value
  value=$(plugin_read_config "${config_key}" "false")
  if [[ "${value}" =~ ^(true|on|1)$ ]]; then
    args+=("${flag}")
  fi
}

main() {
  # Set up error reporting and debug mode
  setup_error_trap
  enable_debug_if_requested

  echo "--- :clock3: Restoring file modification times with git-restore-mtime"

  # Work tree root. Buildkite sets BUILDKITE_BUILD_CHECKOUT_PATH; fall back to
  # the current directory otherwise.
  CHECKOUT_PATH="${BUILDKITE_BUILD_CHECKOUT_PATH:-$PWD}"
  cd "${CHECKOUT_PATH}"

  # `.git` exists (as a dir for normal clones, a file for worktrees/submodules)
  # in any checkout worth restoring; this check needs no git binary on the host,
  # which matters for the docker tool-location.
  if [[ ! -e .git ]] && ! git rev-parse --git-dir >/dev/null 2>&1; then
    log_warning "Not inside a git repository; skipping git-restore-mtime."
    return 0
  fi

  resolve_git_restore_mtime

  local args=()
  add_flag_if_enabled COMMIT_TIME "--commit-time"
  add_flag_if_enabled FIRST_PARENT "--first-parent"
  add_flag_if_enabled SKIP_MISSING "--skip-missing"
  add_flag_if_enabled MERGE "--merge"
  add_flag_if_enabled NO_DIRECTORIES "--no-directories"
  add_flag_if_enabled FORCE "--force"
  add_flag_if_enabled DRY_RUN "--test"
  add_flag_if_enabled VERBOSE "--verbose"
  add_flag_if_enabled QUIET "--quiet"

  local skip_older_than
  skip_older_than=$(plugin_read_config SKIP_OLDER_THAN "")
  if [[ -n "${skip_older_than}" ]]; then
    args+=("--skip-older-than" "${skip_older_than}")
  fi

  # Limit to specific pathspecs when provided.
  if plugin_read_list_into_result PATHS; then
    args+=("${result[@]}")
    log_info "Restoring mtime for paths: $(array_join ", " "${result[@]}")"
  else
    log_info "Restoring mtime for the entire work tree"
  fi

  log_info "Running: ${GRM_CMD[*]} ${args[*]:-}"
  if "${GRM_CMD[@]}" ${args[@]+"${args[@]}"}; then
    log_success "File modification times restored"
  else
    log_error "git-restore-mtime failed"
    exit 1
  fi
}

main "$@"
